generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Portfolio Content ───────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  techStack   String[]
  githubUrl   String
  liveUrl     String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  excerpt     String
  content     String    @db.Text
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Skill {
  id             String @id @default(cuid())
  category       String // Languages | Backend | Mobile | DevOps | Databases
  name           String
  experienceType String @default("personal") // 'professional' | 'personal'
  projects       Json   @default("[]")       // { name: string; githubUrl?: string; liveUrl?: string }[]
  order          Int    @default(0)
}

model Achievement {
  id          String @id @default(cuid())
  icon        String
  title       String
  date        String
  description String
  order       Int    @default(0)
}

model TerminalCommand {
  name      String   @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model PageVisit {
  id        String   @id @default(cuid())
  ipHash    String
  userAgent String?
  referrer  String?
  date      DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  createdAt DateTime @default(now())

  @@index([date])
}

model CommandUsage {
  id        String   @id @default(cuid())
  command   String
  date      DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  createdAt DateTime @default(now())

  @@index([command, date])
}
